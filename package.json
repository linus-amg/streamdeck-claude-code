{
	"name": "streamdeck-claude-code",
	"version": "0.3.2",
	"description": "Stream Deck plugin to control a live Claude Code session — model, effort, fast mode, skills, and native voice — by typing slash commands into the focused terminal.",
	"type": "module",
	"private": true,
	"license": "MIT",
	"packageManager": "bun@1.3.14",
	"scripts": {
		"build": "bun build src/plugin.ts --target=node --format=esm --outdir=com.linus.claude-code-control.sdPlugin/bin --sourcemap=linked",
		"watch": "bun run scripts/dev.ts",
		"typecheck": "tsc --noEmit",
		"validate": "streamdeck validate com.linus.claude-code-control.sdPlugin",
		"package": "streamdeck pack com.linus.claude-code-control.sdPlugin --force --no-update-check"
	},
	"dependencies": {
		"@elgato/streamdeck": "^2.1.0"
	},
	"devDependencies": {
		"@elgato/cli": "^1.7.4",
		"@tsconfig/node20": "^20.1.4",
		"@types/node": "^20.19.43",
		"typescript": "^5.6.0"
	}
}
