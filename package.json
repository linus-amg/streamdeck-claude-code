{
	"name": "streamdeck-claude-code",
	"version": "0.3.2",
	"description": "Stream Deck plugin to steer a live Claude Code session — model, effort, fast mode, and skills — by injecting slash commands into a tmux-hosted TUI.",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "rollup -c",
		"watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.linus.claude-code-control\"",
		"typecheck": "tsc --noEmit",
		"validate": "streamdeck validate com.linus.claude-code-control.sdPlugin",
		"package": "streamdeck pack com.linus.claude-code-control.sdPlugin --force --no-update-check"
	},
	"dependencies": {
		"@elgato/streamdeck": "^2.1.0"
	},
	"devDependencies": {
		"@elgato/cli": "^1.7.4",
		"@rollup/plugin-commonjs": "^28.0.0",
		"@rollup/plugin-node-resolve": "^16.0.0",
		"@rollup/plugin-typescript": "^12.1.0",
		"@tsconfig/node20": "^20.1.4",
		"@types/node": "^20.19.43",
		"rollup": "^4.24.0",
		"tslib": "^2.8.0",
		"typescript": "^5.6.0"
	}
}
